# API + realtime
EXPO_PUBLIC_API_URL=http://localhost:4000/api
EXPO_PUBLIC_SOCKET_URL=http://localhost:4000

# Firebase (web SDK config for Expo)
EXPO_PUBLIC_FIREBASE_API_KEY=xxx
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project
EXPO_PUBLIC_FIREBASE_APP_ID=1:xxx:web:xxx

# Stripe (publishable key)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
EXPO_PUBLIC_STRIPE_MERCHANT_ID=merchant.app.wiselion

# RevenueCat (public SDK keys)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxx

# Wiselion avatar audio CDN base (bingo_1.mp3 ... lotto_99.mp3, drawing.mp3, winner.mp3)
EXPO_PUBLIC_AVATAR_AUDIO_BASE_URL=https://cdn.wiselion.app/audio

# Drop Reel tee artwork CDN base (loads the 10 PNGs remotely; keeps ~60 MB out of
# the app binary). Leave UNSET to use the bundled images. No trailing slash.
EXPO_PUBLIC_DROP_REEL_BASE_URL=https://cdn.wiselion.app/drop-reel
