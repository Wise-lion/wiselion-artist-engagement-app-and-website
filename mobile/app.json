{
  "expo": {
    "name": "Wiselionlikeking",
    "slug": "wiselionlikeking",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "scheme": "wiselion",
    "userInterfaceStyle": "dark",
    "icon": "./assets/wiselion-avatar.png",
    "splash": {
      "image": "./assets/wiselion-avatar.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F1F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.wiselion.king",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Used for live audio features.",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "app.wiselion.king",
      "adaptiveIcon": {
        "foregroundImage": "./assets/wiselion-avatar.png",
        "backgroundColor": "#0A0F1F"
      },
      "permissions": [
        "INTERNET",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.app.wiselion",
          "enableGooglePay": true
        }
      ],
      "expo-av",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      },
      "note": "Public config is read from EXPO_PUBLIC_* env vars at runtime (see src/config.ts). Run `eas init` to populate projectId."
    }
  }
}
