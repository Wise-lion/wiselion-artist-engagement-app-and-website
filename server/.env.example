# ---- Server ----
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173        # admin-web origin for CORS

# ---- Database / Cache ----
DATABASE_URL=postgresql://user:pass@localhost:5432/wiselion?schema=public
REDIS_URL=redis://localhost:6379

# ---- Firebase Admin (service account) ----
# Paste the full service-account JSON as a single line, or use GOOGLE_APPLICATION_CREDENTIALS path.
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PREMIUM_MONTHLY=price_xxx      # Stripe Billing price IDs
STRIPE_PRICE_PREMIUM_YEARLY=price_xxx

# ---- Mux (live streaming) ----
MUX_TOKEN_ID=xxx
MUX_TOKEN_SECRET=xxx

# ---- RevenueCat (in-app coin purchases) ----
REVENUECAT_WEBHOOK_SECRET=your-shared-secret   # matches the Authorization header set in RevenueCat dashboard

# ---- Admin ----
ADMIN_EMAILS=you@example.com,ops@wiselion.app   # comma-separated allowlist for admin-web

# ---- War Room (ClaudeClaw multi-agent automation) ----
WARROOM_URL=ws://localhost:7860             # the War Room WebSocket server (claudeclaw/warroom)
AUTO_PROMOTE=false                          # true = auto-draft promo posts when a drop/draw is scheduled

# ---- Email delivery for approved drafts (resend.com, free tier) ----
RESEND_API_KEY=                             # re_... — when set, "Approve" emails the post
MAIL_FROM="Wiselion War Room <onboarding@resend.dev>"  # free tier requires this sender until you verify a domain
MAIL_TO=wlikeking@gmail.com                 # where approved posts are delivered

# ---- Misc ----
COIN_USD_RATE=0.01                          # 1 coin = $0.01 for web top-ups
